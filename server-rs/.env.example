# ── Required ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/arcadia

# ── Optional (defaults shown) ─────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379
PORT=8080
JWT_SECRET=change-me-in-production

# ── Oracle / chain (enable --features solana) ─────────────────────────────────
PROGRAM_ID=ArcadiaVau1tProgramId11111111111111111111111
ORACLE_KEYPAIR_PATH=/run/secrets/oracle_keypair.json
SOLANA_RPC_URL=https://api.devnet.solana.com

# ── Yellowstone gRPC ingest (enable --features grpc) ─────────────────────────
YELLOWSTONE_ENDPOINT=https://grpc.your-provider.com
YELLOWSTONE_TOKEN=your-token-here

# ── Price feed ────────────────────────────────────────────────────────────────
PYTH_URL=https://hermes.pyth.network
PRICE_MAX_AGE_SECS=10
PRICE_CACHE_TTL_SECS=5
PRICE_INTERVAL_SECS=5

# ── Score worker ──────────────────────────────────────────────────────────────
SCORE_INTERVAL_SECS=3600
