# Kiln — Example environment variables
#
# Copy this file to `.env` (or `.env.local`) and fill in real values before running the app.
# NEVER commit your real `.env` to source control. Treat API keys and DB passwords as secrets.
#
# Notes:
# - Frontend (Vite) variables should be prefixed with VITE_ to be available in the client.
# - The indexer server (Rust Axum) reads HELIUS_API_KEY and DATABASE_URL from the environment.
# - For frontend/demo work, you can avoid Postgres by running the backend with ARCADIA_STORE=memory.
# - Use a dedicated Postgres instance for persistent indexing, production, or shared dev state.
#
# Example usage:
#   cp .env.example .env
#   # edit .env to add secrets
#   pnpm --dir app dev
#   ARCADIA_STORE=memory ARCADIA_DEMO_MODE=true cargo run --manifest-path server-rs/Cargo.toml --bin server-rs
#
# Frontend (Vite) / RPC
# - VITE_RPC_URL: RPC endpoint used by the frontend to talk to Solana.
#   Use a Helius devnet URL or a public devnet RPC. If you have a Helius devnet endpoint,
#   set it here (do not paste secret keys into public repos).
#
VITE_RPC_URL=https://api.devnet.solana.com
VITE_SOLANA_CLUSTER=devnet
VITE_ARCADIA_EXECUTION_ENV=devnet
VITE_ARCADIA_DEMO_MODE=false
VITE_USDC_MINT=DLkVtDD4zfFJzWgGRLqjzqkBhaBs5sVNzDeBCQ2hPgMz
VITE_KILN_API_URL=http://localhost:8080
VITE_KILN_API_BASE_URL=http://localhost:8080
# Example (RPC provider):
# VITE_RPC_URL=https://your-rpc-provider.example.com

# Frontend MagicBlock PER proof flow.
# The app requests a short-lived TEE auth token at runtime with wallet signMessage.
# Optional fallback only: set VITE_MAGICBLOCK_TEE_AUTH_TOKEN for manual smoke tests; never commit a real token.
VITE_MAGICBLOCK_ER_RPC_URL=https://devnet-router.magicblock.app
VITE_MAGICBLOCK_TEE_RPC_URL=https://devnet-tee.magicblock.app
VITE_MAGICBLOCK_TEE_AUTH_TOKEN=
VITE_MAGICBLOCK_ER_VALIDATOR=MTEWGuqxUpYZGFJQcp8tLN7x5v9BSeoFHYWQQ3n3xzo
VITE_MAGICBLOCK_DELEGATION_PROGRAM_ID=DELeGGvXpWV2fqJUhqcF5ZSYMS4JTLjteaAMARRSaeSh
VITE_MAGICBLOCK_PERMISSION_PROGRAM_ID=ACLseoPoyC3cBqoUtkbjZ4aDrkurZW86v19pXz2XQnp1
VITE_MAGICBLOCK_MAGIC_PROGRAM_ID=Magic11111111111111111111111111111111111111
VITE_MAGICBLOCK_MAGIC_CONTEXT_ID=MagicContext1111111111111111111111111111111

# Backend / Indexer (Axum) / Helius
# - HELIUS_API_KEY: API key for Helius webhooks / RPC (if used by your indexer).
#   Leave blank if you rely on a generic RPC provider. Keep this secret.
#
HELIUS_API_KEY=
HELIUS_WEBHOOK_SECRET=
JUPITER_API_KEY=
JUPITER_SWAP_BASE_URL=https://api.jup.ag/swap/v1

# Backend storage mode.
# - memory: easiest local/demo mode. No Postgres required; state resets when server restarts.
# - postgres: persistent indexer mode. Requires DATABASE_URL below and a running Postgres database.
ARCADIA_STORE=memory
ARCADIA_DEMO_MODE=true
ARCADIA_SURFPOOL_MODE=false

# MagicBlock Private ER executor.
# The backend submits private intents to MAGICBLOCK_PRIVATE_ER_ENDPOINT first.
# Production: keep fallback false so MagicBlock outages fail visibly instead of
# producing demo-only local_fallback proofs. Set true only for local demos/tests.
MAGICBLOCK_PRIVATE_ER_ENDPOINT=
MAGICBLOCK_AUTH_TOKEN=
MAGICBLOCK_APP_ID=arcadia-kiln
SOLANA_RPC_URL=https://api.devnet.solana.com
# Magic Router auto-selects the correct base/ER blockhash path for delegated accounts.
MAGICBLOCK_ER_RPC_URL=https://devnet-router.magicblock.app
MAGICBLOCK_TEE_RPC_URL=https://devnet-tee.magicblock.app
MAGICBLOCK_PERMISSION_PROGRAM_ID=ACLseoPoyC3cBqoUtkbjZ4aDrkurZW86v19pXz2XQnp1
MAGICBLOCK_DELEGATION_PROGRAM_ID=DELeGGvXpWV2fqJUhqcF5ZSYMS4JTLjteaAMARRSaeSh
# Optional ER validator identity. Leave blank to let Magic Router choose.
MAGICBLOCK_ER_VALIDATOR=MTEWGuqxUpYZGFJQcp8tLN7x5v9BSeoFHYWQQ3n3xzo
ARCADIA_PROGRAM_ID=49StrXrpxCyC5VkmhossJLWx5nTCvyeoVMbPNMv9WcdN
MAGICBLOCK_MAGIC_PROGRAM_ID=Magic11111111111111111111111111111111111111
MAGICBLOCK_ER_SKIP_PREFLIGHT=true
MAGICBLOCK_ALLOW_LOCAL_FALLBACK=false
MAGICBLOCK_EXECUTOR_TIMEOUT_MS=1500

# Devnet demo USDC faucet.
# Enable only on a trusted dev/demo server. The keypair must control the Arcadia devnet USDC
# source token account and must have enough devnet SOL to fund recipient token accounts.
ARCADIA_DEVNET_FAUCET_ENABLED=false
ARCADIA_DEVNET_USDC_MINT=DLkVtDD4zfFJzWgGRLqjzqkBhaBs5sVNzDeBCQ2hPgMz
ARCADIA_DEVNET_USDC_MINT_AUTHORITY=/path/to/devnet-faucet-authority.json
ARCADIA_DEVNET_FAUCET_AMOUNT=100000
ARCADIA_DEVNET_FAUCET_COOLDOWN_SECS=60
ARCADIA_DEVNET_RPC_URL=https://api.devnet.solana.com

# Postgres connection for the indexer.
# - DATABASE_URL: standard Postgres connection string.
#   Only required when ARCADIA_STORE is unset or not "memory".
#   If your co-founder sees a Postgres connection error, either start Postgres/create this DB
#   or set ARCADIA_STORE=memory for local demo mode.
#
# Example:
# DATABASE_URL=postgres://user:password@localhost:5432/kiln
DATABASE_URL=postgres://postgres:postgres@localhost:5432/kiln

# Server / Indexer listen port
PORT=8080

# App environment
NODE_ENV=development

# Optional: explorer base URL for UI links (devnet or mainnet)
# Used by TxModal for "View on Explorer" links. Keep as devnet in development.
EXPLORER_BASE_URL=https://explorer.solana.com

# Optional: program ID override (if you deploy to devnet and want the frontend to point to a different program)
# PROGRAM_ID=49StrXrpxCyC5VkmhossJLWx5nTCvyeoVMbPNMv9WcdN

# Optional: feature toggles
# ENABLE_INDEXER=true  # enable calling the indexer endpoints from the frontend
# USE_HELIUS_WEBHOOKS=false  # if true, the indexer expects Helius webhook events

# -------------------------
# README note (short)
#
# 1) Copy this file:
#    cp .env.example .env
#
# 2) Edit `.env` and fill in:
#    - VITE_RPC_URL (prefer a Helius devnet RPC or your preferred RPC)
#    - HELIUS_API_KEY (if using Helius webhooks / APIs)
#    - DATABASE_URL only if running persistent Postgres mode
#
# 3) Start services:
#    - Frontend (from repo root): pnpm --dir app dev
#    - Server, no Postgres: ARCADIA_STORE=memory ARCADIA_DEMO_MODE=true cargo run --manifest-path server-rs/Cargo.toml
#    - Server, Postgres: set DATABASE_URL and run `cargo run --manifest-path server-rs/Cargo.toml`
#
# 4) Security:
#    - Do not commit .env to git.
#    - Use a secrets manager / CI variables for production.
#
# 5) Regenerating codegen:
#    - IDL: `pnpm -w codegen:shank` (generates Kiln_program/idl)
#    - SDK: `pnpm --dir clients run generate` (produces clients/src/generated)
#
# If you need me to set up a `.env` for a specific deployment (CI, production, or a hosted Postgres), provide
# the connection string and preferred RPC endpoint, and I will add an environment sample tailored to that setup.
