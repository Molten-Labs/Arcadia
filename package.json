{
  "name": "kiln-workspace",
  "private": true,
  "scripts": {
    "dev": "bash dev.sh",
    "setup": "bash setup.sh",
    "dev:app": "cd app && node node_modules/vite/bin/vite.js --config vite.config.ts",
    "build:app": "cd app && node node_modules/vite/bin/vite.js build --config vite.config.ts",
    "dev:server": "cargo run --manifest-path server-rs/Cargo.toml",
    "build:server": "cargo build --manifest-path server-rs/Cargo.toml",
    "codegen:shank": "shank idl --crate-root Kiln_program/program/src/lib.rs --out-dir idl",
    "codegen:codama": "pnpm --dir clients/ts/kiln codama run --all",
    "codegen": "pnpm codegen:shank && pnpm codegen:codama"
  }
}
