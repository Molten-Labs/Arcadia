modules = ["rust-stable", "nodejs-20", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Mobile Web"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash dev.sh"
waitForPort = 5000

[[workflows.workflow]]
name = "Mobile Web"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash mobile-web.sh"
waitForPort = 8000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8081
externalPort = 8081

[deployment]
deploymentTarget = "static"
build = [
  "bash",
  "-c",
  "cd app && node node_modules/vite/bin/vite.js build --config vite.config.js",
]
publicDir = "app/dist"

[userenv]

[userenv.shared]
VITE_PRIVY_APP_ID = "cmowmjzxf002r0cl5zonkvtai"
VITE_RPC_URL = "https://devnet.helius-rpc.com/?api-key=a901c8af-d871-4edd-b64f-c98d7316ba8b"
VITE_SOLANA_CLUSTER = "devnet"
HELIUS_API_KEY = "a901c8af-d871-4edd-b64f-c98d7316ba8b"
ARCADIA_STORE = "memory"
ARCADIA_DEMO_MODE = "true"
VITE_ARCADIA_DEMO_MODE = "true"
VITE_KILN_API_URL = "/api"
PORT = "8080"
